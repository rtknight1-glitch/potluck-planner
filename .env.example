# Supabase project settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (resend.com) API key, used to send host notifications + guest reminders
RESEND_API_KEY=your-resend-api-key
# Email address Resend sends "from". If you haven't verified a custom domain in Resend,
# use onboarding@resend.dev for testing.
EMAIL_FROM=Potluck Planner <onboarding@resend.dev>

# Secret used to authorize the daily reminder cron job (any random string)
CRON_SECRET=choose-a-random-secret-string

# Base URL of your deployed site, e.g. https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
